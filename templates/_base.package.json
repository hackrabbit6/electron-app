{
  "name": "@electron-app/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A minimal, customizable Electron template",
  "author": "Developer",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist:mac": "node ./scripts/dist-mac.mjs",
    "scaffold": "node ./scripts/setup.mjs",
    "setup": "node ./scripts/setup.mjs",
    "typecheck": "tsc --noEmit && pnpm typecheck:node",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.2",
    "vite": "^7.1.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.example.electronapp",
    "productName": "ElectronApp",
    "directories": {
      "output": "release"
    },
    "mac": {
      "identity": null,
      "hardenedRuntime": false
    },
    "target": ["dmg", "zip"],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
